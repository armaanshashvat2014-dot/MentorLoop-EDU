{
  "manifest_version": 3,
  "name": "MentorLoop EDU",
  "version": "2.0",
  "description": "Learn instantly from any text",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}